# MedBless Backend Environment Variables
PORT=5000
NODE_ENV=development

# Database (XAMPP default: root + empty password — set DB_PASSWORD if yours is different)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=medbless
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=medbless_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Frontend URL
CLIENT_URL=http://localhost:3000
