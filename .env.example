# Copy to .env and adjust. XAMPP MySQL root often has NO password — leave DB_PASSWORD empty.
PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_NAME=medbless
DB_USER=root
DB_PASSWORD=

# Required for the API (MongoDB Atlas or local). Database name in path (e.g. /medbless).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/medbless?retryWrites=true&w=majority

# Optional: defaults for npm run admin:ensure (admins collection, not users)
# ADMIN_EMAIL=krishnaaggarwal2311@gmail.com
# ADMIN_PASSWORD=Admin@1234
# ADMIN_NAME=Krishna Aggarwal

JWT_SECRET=medbless_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:3000
# Comma-separated; add every browser origin (https, no trailing slash). User Netlify add karo jab deploy ho.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://clever-begonia-69b4a5.netlify.app
